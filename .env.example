# Server-only — never commit real keys.
# These are read by api/mentor.js (Vercel serverless). None of them are
# prefixed NEXT_PUBLIC_ / VITE_, so none are ever bundled to the browser.
ANTHROPIC_API_KEY=
SUPABASE_URL=

# Service role key — bypasses RLS so the serverless function can write the
# server-authoritative meter (see supabase-mentor-meter.sql). SERVER ONLY.
# Never ship to the client. Never prefix with NEXT_PUBLIC_ / VITE_.
SUPABASE_SERVICE_ROLE_KEY=

# Anon key is the browser's Supabase key (magic-link auth + RLS reads).
# It is safe to expose to the client and is configured in the front end,
# not used by api/mentor.js.
SUPABASE_ANON_KEY=
